<div class="auth-card" style="padding: 48px 40px; border-radius: 24px;">
  <div style="text-align:center; margin-bottom:32px">
    <div style="margin-bottom:24px">
      <%= image_tag "logo_devender.png", style: "width:180px; height:auto; filter: brightness(0) invert(1); opacity:0.9" %>
    </div>
    <div class="section-label" style="justify-content:center; letter-spacing:3px; font-size:9px">New Access Key</div>
    <h2 style="font-family:var(--font-display); font-size:20px; font-weight:800; color:var(--white); margin-top:12px">Change Password</h2>
  </div>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div style="margin-bottom:20px">
      <label style="display:block; font-size:10px; font-weight:700; text-transform:uppercase; color:var(--cyan); margin-bottom:8px">New Password <% if @minimum_password_length %><em>(<%= @minimum_password_length %> chars min)</em><% end %></label>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "auth-input", placeholder: "••••••••", style: "margin:0" %>
    </div>

    <div style="margin-bottom:24px">
      <label style="display:block; font-size:10px; font-weight:700; text-transform:uppercase; color:var(--cyan); margin-bottom:8px">Confirm New Password</label>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input", placeholder: "••••••••", style: "margin:0" %>
    </div>

    <div class="actions">
      <%= f.submit "Update Access Key", class: "auth-btn", style: "height:54px; font-size:14px; font-weight:800; background:var(--white); color:var(--black); border-radius:12px" %>
    </div>
  <% end %>

  <div style="margin-top:32px; text-align:center; padding-top:24px; border-top:1px solid rgba(255,255,255,0.05)">
    <%= render "devise/shared/links" %>
  </div>
</div>
