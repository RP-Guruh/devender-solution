<div class="auth-links">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Already have an account? Log in", new_session_path(resource_name), class: "auth-footer-link" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Don't have an account? Sign up", new_registration_path(resource_name), class: "auth-footer-link", style: "color:var(--cyan); font-weight:600" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Having trouble signing in?", new_password_path(resource_name), class: "auth-footer-link" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "auth-footer-link" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "auth-footer-link" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "auth-btn", style: "background:transparent; border:1px solid rgba(255,255,255,0.1); color:var(--white) !important; height:44px; font-size:12px; margin-top:10px" %>
    <% end %>
  <% end %>
</div>
