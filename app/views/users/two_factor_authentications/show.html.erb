<style>
  .two_factor_authentications-page main {
    padding: 0;
  }
  
  .auth-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 24px 100px;
    background: radial-gradient(circle at center, rgba(0, 200, 232, 0.05) 0%, transparent 70%);
  }

  .premium-auth-card {
    width: 100%;
    max-width: 460px;
    background: #1A1A1A;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    padding: 48px;
    text-align: center;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
  }

  .otp-input-field {
    width: 100%;
    background: rgba(0, 0, 0, 0.2) !important;
    border: 2px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 14px !important;
    padding: 18px !important;
    font-size: 28px !important;
    font-weight: 800 !important;
    color: #fff !important;
    text-align: center !important;
    letter-spacing: 10px !important;
    margin: 20px 0 !important;
    outline: none !important;
  }

  .auth-btn {
    width: 100%;
    background: #00C8E8;
    color: #000;
    border: none;
    padding: 18px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 15px;
    cursor: pointer;
    text-transform: uppercase;
  }
</style>

<section class="auth-section">
  <div class="premium-auth-card">
    <div style="width: 64px; height: 64px; background: rgba(0, 200, 232, 0.1); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
      <i data-lucide="lock" style="width: 30px; height: 30px; color: #00C8E8;"></i>
    </div>
    
    <h2 style="font-family: var(--font-display); font-size: 28px; font-weight: 800; color: #fff; margin-bottom: 8px;">Verification Required</h2>
    <p style="font-size: 14px; color: var(--muted); margin-bottom: 32px;">Enter the security code from your authenticator app.</p>

    <% flash.each do |type, message| %>
      <div style="padding: 12px; border-radius: 8px; margin-bottom: 24px; font-size: 13px; color: #ff4444; background: rgba(255,68,68,0.1); border: 1px solid rgba(255,68,68,0.15);">
        <%= message %>
      </div>
    <% end %>

    <%= form_with url: two_factor_authentication_path, method: :post do |f| %>
      <%= f.text_field :otp_attempt, 
          placeholder: "······",
          class: "otp-input-field",
          autocomplete: 'one-time-code',
          inputmode: 'numeric',
          maxlength: 6,
          autofocus: true,
          required: true %>
      
      <div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 24px;">
        <input type="checkbox" name="remember_device" value="1" style="accent-color:#00C8E8; width:16px; height:16px;">
        <label style="font-size: 13px; color: var(--muted);">Remember this device</label>
      </div>

      <%= f.submit 'Verify & Log In', class: "auth-btn" %>
    <% end %>
  </div>
</section>