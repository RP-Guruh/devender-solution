<div class="pagination-container">
  <div class="pagination-info">
    <% start_item = total_count > 0 ? (current_page - 1) * per_page + 1 : 0 %>
    <% end_item = [current_page * per_page, total_count].min %>
    Showing <span><%= start_item %></span> to <span><%= end_item %></span> of <span><%= total_count %></span> results
  </div>

  <div class="pagination-nav">
    <% base_params = request.query_parameters %>

    <%# ===== PREVIOUS ===== %>
    <% if current_page > 1 %>
      <%= link_to url_for(base_params.merge(page: current_page - 1)),
                  data: { turbo_frame: frame_id },
                  class: "page-link",
                  title: "Previous Page" do %>
        <i data-lucide="chevron-left" class="page-icon"></i>
      <% end %>
    <% else %>
      <div class="page-link disabled">
        <i data-lucide="chevron-left" class="page-icon"></i>
      </div>
    <% end %>

    <%# ===== WINDOW LOGIC ===== %>
    <% 
      max_pages = 5
      start_page = [1, current_page - (max_pages / 2)].max
      end_page = [total_pages, start_page + max_pages - 1].min
      start_page = [1, end_page - max_pages + 1].max
    %>

    <%# ===== FIRST PAGE ===== %>
    <% if start_page > 1 %>
      <%= link_to "1",
          url_for(base_params.merge(page: 1)),
          data: { turbo_frame: frame_id },
          class: "page-link" %>

      <% if start_page > 2 %>
        <div class="page-link disabled">...</div>
      <% end %>
    <% end %>

    <%# ===== PAGE NUMBERS ===== %>
    <% (start_page..end_page).each do |p| %>
      <%= link_to p,
          url_for(base_params.merge(page: p)),
          data: { turbo_frame: frame_id },
          class: "page-link #{'active' if p == current_page}" %>
    <% end %>

    <%# ===== LAST PAGE ===== %>
    <% if end_page < total_pages %>
      <% if end_page < total_pages - 1 %>
        <div class="page-link disabled">...</div>
      <% end %>

      <%= link_to total_pages,
          url_for(base_params.merge(page: total_pages)),
          data: { turbo_frame: frame_id },
          class: "page-link" %>
    <% end %>

    <%# ===== NEXT ===== %>
    <% if current_page < total_pages %>
      <%= link_to url_for(base_params.merge(page: current_page + 1)),
                  data: { turbo_frame: frame_id },
                  class: "page-link",
                  title: "Next Page" do %>
        <i data-lucide="chevron-right" class="page-icon"></i>
      <% end %>
    <% else %>
      <div class="page-link disabled">
        <i data-lucide="chevron-right" class="page-icon"></i>
      </div>
    <% end %>
  </div>
</div>