<% content_for :page_title, "New Setting" %>
<div class="admin-header">
  <div>
    <%= link_to admin_settings_path, style: "text-decoration: none; display: flex; align-items: center; gap: 8px; color: var(--text-muted); font-size: 13px; font-weight: 600; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;" do %>
      <i data-lucide="arrow-left" style="width: 14px"></i>
      <span>Back to Settings</span>
    <% end %>
    <h1 class="page-title" style="font-size: 32px;">Create New Setting</h1>
  </div>
</div>

<div class="admin-card">
  <%= render "form", setting: @setting %>
</div>
