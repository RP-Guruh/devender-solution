<%= form_with(model: [:admin, setting]) do |form| %>
  <% if setting.errors.any? %>
    <div class="form-error-box">
      <div class="form-error-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <div>
        <h2 class="form-error-title"><%= pluralize(setting.errors.count, "error") %> prohibited this setting from being saved:</h2>
        <ul class="form-error-list">
          <% setting.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :key, class: "form-label" %>
    <%= form.text_field :key, class: "form-input", placeholder: "e.g. site_name" %>
    <p class="form-hint">Unique identifier for the setting.</p>
  </div>

  <div class="form-group">
    <%= form.label :value, class: "form-label" %>
    <%= form.text_area :value, class: "form-input form-textarea", placeholder: "Enter setting value..." %>
  </div>

  <%= render "shared/admin/confirm_dialog",
        form: form,
        title: "Konfirmasi Perubahan",
        description: "Apakah Anda yakin ingin menyimpan pengaturan ini? Perubahan akan langsung diterapkan ke sistem.",
        trigger_label: "Save Setting",
        confirm_label: "Ya, Simpan",
        cancel_path: admin_settings_path %>

<% end %>
