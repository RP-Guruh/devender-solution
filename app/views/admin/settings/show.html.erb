<% content_for :page_title, "Setting Details" %>
<div class="admin-header">
  <div>
    <%= link_to admin_settings_path, style: "text-decoration: none; display: flex; align-items: center; gap: 8px; color: var(--text-muted); font-size: 13px; font-weight: 600; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;" do %>
      <i data-lucide="arrow-left" style="width: 14px"></i>
      <span>Back to Settings</span>
    <% end %>
    <h1 class="page-title" style="font-size: 32px;">Setting Details</h1>
  </div>
  <div style="display: flex; gap: 12px;">
    <%= link_to edit_admin_setting_path(@setting), class: "btn-admin btn-admin-primary" do %>
      <i data-lucide="edit-3" style="width: 18px"></i>
      <span>Edit Setting</span>
    <% end %>
    <%= button_to [:admin, @setting], method: :delete, class: "btn-admin btn-admin-danger", form: { data: { turbo_confirm: "Are you sure you want to delete this setting?" } } do %>
      <i data-lucide="trash-2" style="width: 18px"></i>
      <span>Delete</span>
    <% end %>
  </div>
</div>

<% if notice.present? %>
  <div style="background: rgba(0, 200, 232, 0.1); border: 1px solid rgba(0, 200, 232, 0.2); color: var(--cyan); padding: 12px 20px; border-radius: 8px; margin-bottom: 24px; font-size: 14px; display: flex; align-items: center; gap: 12px;">
    <i data-lucide="check-circle" style="width: 18px"></i>
    <%= notice %>
  </div>
<% end %>

<div class="admin-card">
  <div style="display: grid; grid-template-columns: 200px 1fr; gap: 40px; align-items: start;">
    <div>
      <h3 style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 12px;">Setting Key</h3>
      <span class="badge-key" style="font-size: 16px; padding: 6px 12px;"><%= @setting.key %></span>
    </div>
    <div>
      <h3 style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 12px;">Stored Value</h3>
      <div style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 24px; color: rgba(255,255,255,0.9); font-size: 16px; line-height: 1.6; min-height: 100px; white-space: pre-wrap;">
        <%= @setting.value %>
      </div>
    </div>
  </div>
  
  <div style="margin-top: 60px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center;">
    <div style="display: flex; gap: 24px;">
      <div>
        <span style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Created</span>
        <p style="font-size: 13px; color: #fff; margin-top: 4px;"><%= @setting.created_at.strftime("%B %d, %Y at %H:%M") %></p>
      </div>
      <div>
        <span style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Last Updated</span>
        <p style="font-size: 13px; color: #fff; margin-top: 4px;"><%= @setting.updated_at.strftime("%B %d, %Y at %H:%M") %></p>
      </div>
    </div>
  </div>
</div>
