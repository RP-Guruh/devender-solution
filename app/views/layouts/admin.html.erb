<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Devender — Dashboard</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --admin-bg: #0A0A0A;
        --card-bg: #121212;
        --border-color: rgba(255, 255, 255, 0.05);
        --accent: #00C8E8;
        --text-muted: #888;
        --sidebar-width: 280px;
      }

      body { font-family: 'Inter', sans-serif; background: var(--admin-bg); color: #fff; margin: 0; }

      .admin-layout { display: flex; min-height: 100vh; position: relative; overflow-x: hidden; }
      
      /* Sidebar */
      .sidebar {
        width: var(--sidebar-width); background: #000; border-right: 1px solid var(--border-color);
        display: flex; flex-direction: column; padding: 32px 20px;
        position: fixed; top: 0; bottom: 0; left: 0; z-index: 100;
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .sidebar-logo { padding: 0 12px 40px; }
      .nav-group { margin-bottom: 32px; }
      .nav-label { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; padding: 0 12px; }
      .nav-link {
        display: flex; align-items: center; gap: 12px; padding: 12px;
        color: #aaa; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 500;
        transition: 0.2s;
      }
      .nav-link:hover, .nav-link.active { background: rgba(255,255,255,0.03); color: #fff; }
      .nav-link.active { color: var(--accent); }

      /* Main Content */
      .main-content { margin-left: var(--sidebar-width); flex: 1; display: flex; flex-direction: column; transition: margin 0.4s; min-width: 0; }
      
      .top-nav {
        height: 72px; padding: 0 40px; display: flex; align-items: center; justify-content: space-between;
        border-bottom: 1px solid var(--border-color); background: rgba(10,10,10,0.8); backdrop-filter: blur(12px);
        position: sticky; top: 0; z-index: 90;
      }
      
      .menu-toggle { display: none; background: none; border: none; color: #fff; cursor: pointer; padding: 0; margin-right: 16px; }
      
      .page-title { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 18px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

      .admin-container { padding: 40px; max-width: 1400px; width: 100%; box-sizing: border-box; }

      /* Overlay */
      .sidebar-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);
        z-index: 95; opacity: 0; pointer-events: none; transition: opacity 0.3s;
      }

      @media (max-width: 1100px) {
        :root { --sidebar-width: 80px; }
        .sidebar-text, .nav-label, .sidebar-logo img { display: none; }
        .sidebar-logo { text-align: center; padding-bottom: 20px; }
        .sidebar-logo::after { content: 'D'; font-weight: 900; color: var(--accent); font-size: 24px; }
        .nav-link { justify-content: center; padding: 15px; }
        .nav-link i { width: 20px !important; }
      }

      @media (max-width: 768px) {
        :root { --sidebar-width: 280px; }
        .sidebar { transform: translateX(-100%); width: var(--sidebar-width); }
        .sidebar.open { transform: translateX(0); }
        .sidebar-text, .nav-label, .sidebar-logo img { display: block; }
        .sidebar-logo::after { display: none; }
        .nav-link { justify-content: flex-start; }
        
        .sidebar-overlay.open { opacity: 1; pointer-events: auto; }
        
        .main-content { margin-left: 0; }
        .top-nav { padding: 0 20px; }
        .menu-toggle { display: block; }
        .admin-container { padding: 24px 20px; }
        
        .user-info-text { display: none; }
      }
    </style>
  </head>

  <body>
    <div class="admin-layout">
      <div class="sidebar-overlay" id="sidebarOverlay"></div>
      
      <!-- SIDEBAR -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
          <%= image_tag "logo_devender.png", style: "width:140px; height:auto; filter: brightness(0) invert(1)" %>
        </div>
        
        <div class="nav-group">
          <div class="nav-label">General</div>
          <%= link_to admin_dashboard_path, class: "nav-link #{'active' if current_page?(admin_dashboard_path)}" do %>
            <i data-lucide="layout-grid" style="width:18px"></i>
            <span class="sidebar-text">Dashboard</span>
          <% end %>
          <a href="#" class="nav-link">
            <i data-lucide="folder" style="width:18px"></i>
            <span class="sidebar-text">Project List</span>
          </a>
        </div>

        <div class="nav-group">
          <div class="nav-label">Management</div>
             <a href="<%= admin_companies_path %>" class="nav-link #{'active' if controller_name == 'companies'}"">
            <i data-lucide="building-2" style="width:18px"></i>
            <span class="sidebar-text">Clients</span>
          </a>
          <a href="<%= admin_settings_path %>" class="nav-link #{'active' if controller_name == 'settings'}"">
            <i data-lucide="settings" style="width:18px"></i>
            <span class="sidebar-text">Settings</span>
          </a>
       
        </div>

        <div style="margin-top:auto">
          <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link", style: "color:#ff4444" do %>
            <i data-lucide="log-out" style="width:18px"></i>
            <span class="sidebar-text">Logout</span>
          <% end %>
        </div>
      </aside>

      <!-- MAIN -->
      <div class="main-content">
        <header class="top-nav">
          <div style="display:flex; align-items:center">
            <button class="menu-toggle" id="menuToggle">
              <i data-lucide="menu"></i>
            </button>
            <div class="page-title"><%= yield(:page_title).presence || "Dashboard" %></div>
          </div>
          
          <div style="display:flex; align-items:center; gap:16px">
            <div style="text-align:right" class="user-info-text">
              <div style="font-weight:600; font-size:14px"><%= current_user.email %></div>
              <div style="font-size:11px; color:var(--text-muted)">Administrator</div>
            </div>
            <div style="width:40px; height:40px; border-radius:50%; background:var(--card-bg); border:1px solid var(--border-color); display:flex; align-items:center; justify-content:center; flex-shrink: 0;">
              <i data-lucide="user" style="width:18px; color:var(--accent)"></i>
            </div>
          </div>
        </header>

        <main class="admin-container">
          <%= yield %>
        </main>
      </div>
    </div>

    <script>
      $(document).ready(function() {
        lucide.createIcons();

        // Mobile Sidebar Toggle
        $('#menuToggle, #sidebarOverlay').on('click', function() {
          $('#sidebar').toggleClass('open');
          $('#sidebarOverlay').toggleClass('open');
        });

        // Close sidebar on link click (for mobile SPA feel)
        $('.nav-link').on('click', function() {
          if (window.innerWidth <= 768) {
            $('#sidebar').removeClass('open');
            $('#sidebarOverlay').removeClass('open');
          }
        });
      });

      // Re-initialize after turbo navigation
      $(document).on('turbo:load', function() {
        lucide.createIcons();
      });
    </script>
  </body>
</html>
