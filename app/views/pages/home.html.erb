<%= render 'hero' %>

<% 
  services_str = @settings['devender_services'] || "Web Design | Brand Identity | UI / UX | Web Development | Mobile Apps"
  service_items = services_str.split('|').map(&:strip)
%>
<!-- MARQUEE -->
<div class="marquee-section">
  <div class="marquee-track" id="marquee">
    <% 2.times do %>
      <% service_items.each do |item| %>
        <div class="marquee-item"><%= item %> <span class="sep">✦</span></div>
      <% end %>
    <% end %>
  </div>
</div>

<%= render 'services' %>
<%= render 'work' %>
